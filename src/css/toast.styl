/* 轻量提示框（Toast） */

.toast-overlay
    position: fixed
    top: 0
    left: 0
    right: 0
    bottom: 0
    background: rgba(0, 0, 0, 0.45)
    z-index: 1100
    display: flex
    align-items: center
    justify-content: center

.toast-modal
    background: rgba(20, 20, 40, 0.95)
    border: 2px solid #d4af37
    border-radius: 12px
    padding: 0
    min-width: 180px
    max-width: 380px
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5)

.toast-header
    display: flex
    align-items: center
    justify-content: space-between
    padding: 8px 14px
    border-bottom: 1px solid rgba(212, 175, 55, 0.3)

.toast-title
    font-size: 16px
    color: #d4af37
    font-weight: bold
    text-shadow: 1px 1px 2px #000

.toast-close
    background: none
    border: none
    color: #aaa
    font-size: 20px
    cursor: pointer
    padding: 0 4px
    line-height: 1
    &:hover
        color: #fff

.toast-body
    padding: 12px 16px
    text-align: center

.toast-tiles
    display: flex
    justify-content: center
    gap: 2px
    margin-bottom: 8px

    .toast-tile
        display: inline-block
        img
            width: 28px
            height: 39px

.toast-text
    font-size: 15px
    color: #e0e0e0
    line-height: 1.6
    margin-bottom: 8px

.toast-timer
    font-size: 12px
    color: #888
