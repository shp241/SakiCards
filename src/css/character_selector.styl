.character-selector-overlay
    position: fixed
    left: 0
    top: 0
    right: 0
    bottom: 0
    z-index: 10000
    background: rgba(0,0,0,0.85)
    display: flex
    align-items: center
    justify-content: center
    flex-direction: column

.character-selector-toggle
    position: absolute
    top: 12px
    left: 50%
    transform: translateX(-50%)
    font-family: text-font
    font-size: 15px
    padding: 6px 24px
    min-width: 90px
    background: rgba(74,74,138,0.6)
    color: #ddd
    border: 1px solid #6666aa
    border-radius: 6px
    cursor: pointer
    z-index: 10001
    &:hover
        background: rgba(90,90,154,0.8)
        color: #fff

.character-selector-modal
    position: relative
    width: 1100px
    max-height: 92vh
    background: #1a1a2e
    border: 2px solid #4a4a8a
    border-radius: 12px
    padding: 24px
    overflow: hidden
    display: flex
    flex-direction: column

.character-selector-title
    text-align: center
    font-family: title-font
    font-size: 28px
    color: #f0d060
    margin-bottom: 16px
    flex-shrink: 0

.character-selector-grid
    overflow-y: auto
    display: grid
    grid-template-columns: repeat(4, 1fr)
    gap: 14px
    padding: 8px 4px
    flex: 1
    min-height: 0
    align-content: start
    /* 只有少量角色时居中 */
    &.few-cards
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr))
        justify-content: center
    /* 多角色时横向滚动 */
    &.many-cards
        overflow-y: hidden
        overflow-x: auto
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr))
        grid-auto-flow: column
        grid-auto-columns: minmax(200px, 220px)
        gap: 10px
        padding: 8px 8px
        scroll-behavior: smooth
        .character-card
            padding: 8px
            .avatar
                width: 80px
                height: 80px
                margin-bottom: 8px
            .char-name
                font-size: 15px
                margin-bottom: 6px
            .char-skills
                font-size: 11px
                line-height: 1.5
                max-height: 120px
                overflow-y: auto

.character-card
    background: #222244
    border: 2px solid #333366
    border-radius: 8px
    padding: 10px
    cursor: pointer
    text-align: center
    transition: border-color 0.15s, background 0.15s
    display: flex
    flex-direction: column
    align-items: center
    &:hover
        background: #2a2a55
        border-color: #8888cc
    &.selected
        border-color: #f0d060
        background: #3a3a22
        box-shadow: 0 0 10px rgba(240,208,96,0.3)
    .avatar
        width: 100px
        height: 100px
        border-radius: 50%
        object-fit: cover
        margin-bottom: 10px
        flex-shrink: 0
    .char-name
        font-family: text-font
        font-size: 17px
        color: #eee
        margin-bottom: 8px
        white-space: nowrap
        overflow: hidden
        text-overflow: ellipsis
        max-width: 100%
    .char-skills
        font-family: text-font
        font-size: 13px
        color: #aaa
        line-height: 1.65
        text-align: left
        width: 100%
        .skill-line
            word-break: break-all

.character-selector-confirm
    text-align: center
    margin-top: 16px
    flex-shrink: 0

.character-selector-btn
    font-family: text-font
    font-size: 18px
    padding: 8px 48px
    background: #4a4a8a
    color: #ccc
    border: 2px solid #6666aa
    border-radius: 6px
    cursor: pointer
    &:hover:not(:disabled)
        background: #5a5a9a
        color: #fff
    &:disabled
        background: #333
        border-color: #444
        color: #666
        cursor: not-allowed

.ai-choosing
    font-family: text-font
    font-size: 22px
    color: #f0d060
    text-align: center
    padding: 60px 0
    grid-column: 1 / -1

/* ===== 对局中角色显示 ===== */

.character-display
    position: absolute
    z-index: 10
    display: flex
    flex-direction: column
    align-items: center
    pointer-events: none
    &.main
        transform: translate(60px, 520px)
    &.xiajia
        transform: translate(680px, 480px)
    &.duimian
        transform: translate(700px, 40px)
    &.shangjia
        transform: translate(60px, 80px)
    .char-avatar
        width: 56px
        height: 56px
        border-radius: 50%
        object-fit: cover
        border: 2px solid #f0d060
        cursor: pointer
        pointer-events: auto
        &:hover
            box-shadow: 0 0 8px rgba(240,208,96,0.5)
    .char-name
        font-family: text-font
        font-size: 12px
        color: #eee
        margin-top: 4px
        text-align: center
        max-width: 120px
        white-space: nowrap
        overflow: hidden
        text-overflow: ellipsis

/* ===== 技能浮窗 ===== */

.skill-popup
    position: fixed
    z-index: 10010
    top: 50%
    left: 50%
    transform: translate(-50%, -50%)
    width: 280px
    max-height: 65vh
    overflow-y: auto
    background: #1a1a2e
    border: 2px solid #4a4a8a
    border-radius: 8px
    padding: 14px
    .skill-popup-name
        font-family: text-font
        font-size: 18px
        color: #f0d060
        text-align: center
        margin-bottom: 10px
        padding-bottom: 8px
        border-bottom: 1px solid #4a4a8a
    .skill-popup-item
        font-family: text-font
        font-size: 13px
        color: #ccc
        line-height: 1.65
        margin-bottom: 8px
        word-break: break-all
        &:last-child
            margin-bottom: 0
