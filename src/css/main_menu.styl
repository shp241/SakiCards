/* 主菜单 */
#main-menu
    display: none
    position: fixed
    left: 0
    top: 0
    right: 0
    bottom: 0
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%)
    z-index: 1000
    overflow-y: auto

    .menu-container
        max-width: 900px
        margin: 0 auto
        padding: 30px 20px

    .menu-title
        text-align: center
        margin-bottom: 16px
        h1
            font-family: title-font
            font-size: 42px
            color: #d4a84b
            margin: 0
            text-shadow: 0 2px 8px rgba(212, 168, 75, 0.3)
        .subtitle
            font-family: text-font
            font-size: 14px
            color: #888
            margin-top: 4px

    .menu-grid
        display: grid
        grid-template-columns: repeat(5, 1fr)
        gap: 16px
        margin-top: 24px

    .menu-card
        background: rgba(255, 255, 255, 0.06)
        border: 1px solid rgba(255, 255, 255, 0.1)
        border-radius: 10px
        padding: 20px 12px
        text-align: center
        cursor: pointer
        transition: all 0.2s ease
        text-decoration: none
        display: block
        color: inherit

        &:hover
            background: rgba(212, 168, 75, 0.12)
            border-color: rgba(212, 168, 75, 0.4)
            transform: translateY(-3px)
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3)

        .card-icon
            font-size: 36px
            margin-bottom: 10px
            display: block

        .card-name
            font-family: title-font
            font-size: 17px
            color: #e0d5c0
            margin-bottom: 4px

        .card-desc
            font-family: text-font
            font-size: 11px
            color: #888
            line-height: 1.4

    .menu-card.start-game
        background: rgba(212, 168, 75, 0.1)
        border-color: rgba(212, 168, 75, 0.3)
        &:hover
            background: rgba(212, 168, 75, 0.2)
            border-color: rgba(212, 168, 75, 0.6)

    .version-info
        text-align: center
        margin-top: 30px
        font-family: menu-font
        font-size: 12px
        color: #555

/* 当主菜单显示时，隐藏 title */
body.title #main-menu.active
    display: block
body.title.menu #title
body.title.menu #navi
    display: none

/* ── 横屏适配 ── */
@media screen and (max-height: 450px)
    #main-menu
        overflow-y: auto
        .menu-container
            padding: 12px 20px
        .menu-title
            margin-bottom: 8px
            h1
                font-size: 26px
            .subtitle
                font-size: 11px
                margin-top: 2px
        .menu-grid
            grid-template-columns: repeat(2, 1fr)
            gap: 10px
            margin-top: 10px
            max-width: 460px
            margin-left: auto
            margin-right: auto
        .menu-card
            padding: 14px 16px
            border-radius: 8px
            .card-icon
                font-size: 26px
                margin-bottom: 6px
            .card-name
                font-size: 15px
                margin-bottom: 3px
            .card-desc
                font-size: 11px
                line-height: 1.4
        .version-info
            margin-top: 12px
            font-size: 10px