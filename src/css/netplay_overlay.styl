/* 联机对战 - 角色选择器 & 技能提示 */

.netplay-char-select-overlay
    position: fixed
    top: 0
    left: 0
    width: 100%
    height: 100%
    background: rgba(0,0,0,0.85)
    z-index: 10000
    display: flex
    align-items: center
    justify-content: center

.netplay-char-select-modal
    background: #111
    border: 2px solid #666
    padding: 20px
    max-width: 400px
    width: 90%
    text-align: center

.netplay-char-select-title
    color: white
    font-size: 1.2em
    margin-bottom: 15px

.netplay-char-select-grid
    display: flex
    flex-wrap: wrap
    gap: 10px
    justify-content: center
    margin-bottom: 15px

.netplay-char-card
    width: 100px
    padding: 8px
    background: #222
    border: 1px solid #444
    border-radius: 4px
    cursor: pointer
    text-align: center
    transition: border-color 0.2s
    &:hover
        border-color: #888
    &.selected
        border-color: #ffd700
        background: #333
    img
        width: 60px
        height: 60px
        border-radius: 50%
        object-fit: cover
    .netplay-char-name
        color: white
        font-size: 0.9em
        margin-top: 6px
    .netplay-char-skills
        margin-top: 4px
        font-size: 0.75em
        color: #aaa
        div
            white-space: nowrap
            overflow: hidden
            text-overflow: ellipsis

.netplay-char-select-btn
    padding: 8px 32px
    font-size: 1em
    cursor: pointer
    background: #333
    color: white
    border: 1px solid #666
    border-radius: 4px
    &:disabled
        opacity: 0.3
        cursor: not-allowed
    &:not(:disabled):hover
        background: #555


.netplay-skill-prompt-overlay
    position: fixed
    top: 0
    left: 0
    width: 100%
    height: 100%
    background: rgba(0,0,0,0.6)
    z-index: 10000
    display: flex
    align-items: center
    justify-content: center

.netplay-skill-prompt-modal
    background: #111
    border: 2px solid #666
    padding: 20px
    max-width: 300px
    width: 90%
    text-align: center

.netplay-skill-prompt-text
    color: white
    font-size: 1.1em
    margin-bottom: 15px

.netplay-skill-prompt-buttons
    display: flex
    gap: 10px
    justify-content: center

.netplay-skill-prompt-btn
    padding: 8px 20px
    font-size: 0.9em
    cursor: pointer
    background: #333
    color: white
    border: 1px solid #666
    border-radius: 4px
    &:hover
        background: #555
    border-radius: 3px
    background: #fffef0
