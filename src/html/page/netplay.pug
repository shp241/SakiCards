- var page = 'netplay'

doctype html
html(lang="zh-CN")
  
  head
    include ../inc/meta

    include ../inc/ogp
    +ogp('超能力麻将: 网络对战', '基于WebSocket的麻将服务器', 
          'https://kobalab.net/majiang/img/netplay.png')

    include ../inc/style
    script(src="server/socket.io/socket.io.js" defer)
    include ../inc/script
  
  body.title
    include ../inc/loaderr
